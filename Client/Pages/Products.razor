                    </div>
                    <div class="widget">
                        <h5 class="widget-title">Filter by Size</h5>
                        <ul class="widget-size">
                            <li class="active_size" id="size_1"><a data-size="1" id="S" class="filter_by_size" href="javascript:void(0);">S</a></li>
                            <li class="active_size" id="size_2"><a data-size="2" id="M" class="filter_by_size" href="javascript:void(0);">M</a></li>
                            <li class="active_size active" id="size_3"><a data-size="3" id="L" class="filter_by_size" href="javascript:void(0);">L</a></li>
                            <li class="active_size" id="size_4"><a data-size="4" id="XL" class="filter_by_size" href="javascript:void(0);">XL</a></li>
